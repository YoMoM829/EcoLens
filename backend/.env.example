# ============================================================================
# EcoLens Backend Configuration - Copy to .env and fill in your values
# ============================================================================

# AWS Configuration
AWS_REGION=us-east-1

# S3 Buckets (three vars required — can all point to the same bucket)
S3_UPLOAD_BUCKET=ecolens-uploads-dev
S3_THUMBNAIL_BUCKET=ecolens-thumbnails-dev
S3_DETECTIONS_BUCKET=ecolens-uploads-dev

# AWS Cognito (for JWT verification)
# Set these to match your Cognito user pool configuration
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS SNS (for tag-based email notifications) - Optional
# Leave empty to disable notifications during development
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ecolens-tags

# CORS - CloudFront distribution URL (required in production)
# Without this, browser API calls from the deployed frontend will be blocked.
# Leave empty for local development (localhost is always allowed).
FRONTEND_ORIGIN=

# ============================================================================
# OCI NoSQL Configuration
# Leave these empty for local development (uses local JSON instead)
# Fill in for production deployment to OCI
# ============================================================================

# Set USE_OCI_DB=1 to enable OCI NoSQL; leave unset (or 0) to use local JSON (not safe in Lambda)
USE_OCI_DB=0
OCI_REGION=us-ashburn-1
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_NOSQL_TABLE_NAME=media_metadata
OCI_NOSQL_COMPARTMENT_OCID=ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OCI API Key - one of:
# 1. OCI_PRIVATE_KEY_PATH=/path/to/private/key (file path to API private key)
# 2. OCI_PRIVATE_KEY_CONTENT=-----BEGIN RSA PRIVATE KEY-----\n... (inline key content)
OCI_PRIVATE_KEY_PATH=

# OCI private key passphrase (if key is encrypted) - Optional
OCI_PASSPHRASE=

# OCI NoSQL custom endpoint (if using emulator or custom endpoint) - Optional
OCI_NOSQL_ENDPOINT=

# ============================================================================
# Local Development Notes
# ============================================================================
# For local development with minimal setup:
# 1. Fill in AWS_REGION, COGNITO_USER_POOL_ID, COGNITO_CLIENT_ID
# 2. Fill in S3 bucket names (or use defaults)
# 3. Leave all OCI settings empty (local JSON catalog will be used)
# 4. Leave SNS_TOPIC_ARN empty unless testing notifications
#
# Start the dev server with:
#   python -m uvicorn backend.src.main:app --reload --host 127.0.0.1 --port 8000
# ============================================================================
