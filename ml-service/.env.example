# ============================================================================
# EcoLens ML pipeline configuration
# Copy to .env for local inference testing: cp .env.example .env
# ============================================================================
# This package performs model inference only. S3, metadata, and SNS are handled
# by ../backend/src/tagging_handler.py and ../backend/src/repository.py.

# ============================================================================
# Model paths (required for local inference)
# ============================================================================
# Defaults resolve to ml-service/models/ when unset.
# MEGADETECTOR_PATH=./models/mdv5a.pt
# SPECIES_MODEL_PATH=./models/model.pt

# ============================================================================
# Inference tuning (optional)
# ============================================================================
# CLASSIFICATION_CONF_THRESHOLD=0.8
# VIDEO_FRAME_RATE=1.0
# MAX_VIDEO_FRAMES=0
# DETECTOR_BATCH_SIZE=8
# CLASSIFIER_BATCH_SIZE=32
# LOWER_CONF=0.05
# SNIP_SIZE=600
# CLASSIFICATION_IMAGE_SIZE=480
# ANIMAL_CATEGORY_ID=1

# ============================================================================
# Runtime directories (optional; defaults use /tmp in Lambda-like environments)
# ============================================================================
# CROP_OUTPUT_DIR=/tmp/cropped_images
# FRAME_OUTPUT_DIR=/tmp/video_frames

# ============================================================================
# Local testing
# ============================================================================
#   cd ml-service
#   python -m pip install -r requirements.txt
#   python tests/test_local.py path/to/image.jpg
#
# Full upload flow (S3 handler + metadata):
#   python ../backend/tests/test_local_s3_trigger.py
