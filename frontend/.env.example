# ============================================================================
# EcoLens Frontend Configuration - Copy to .env.local and fill in your values
# ============================================================================
# Vite exposes environment variables prefixed with VITE_ to the browser
# Reference: https://vitejs.dev/guide/env-and-mode.html

# ============================================================================
# API Configuration
# ============================================================================
# Backend API base URL
# Local development: http://localhost:8000
# Production: https://api.ecolens.example.com or your API Gateway URL
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# AWS Cognito Configuration
# ============================================================================
# Must match the Cognito user pool region and client ID configured in your AWS account
# These are the SAME values as in backend/.env

# AWS region where your Cognito user pool is hosted
VITE_COGNITO_REGION=us-east-1

# Cognito app client ID for this frontend application
# This is a public identifier (safe to expose in browser code)
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Optional: Analytics & Monitoring
# ============================================================================
# Uncomment to enable error tracking, analytics, or other services
# VITE_SENTRY_DSN=https://...
# VITE_GA_MEASUREMENT_ID=G-...

# ============================================================================
# Local Development Notes
# ============================================================================
# 1. Copy this file: cp frontend/.env.example frontend/.env.local
# 2. Fill in VITE_API_BASE_URL (usually http://localhost:8000 during dev)
# 3. Fill in VITE_COGNITO_REGION and VITE_COGNITO_CLIENT_ID from your AWS Cognito setup
# 4. Run: npm run dev
#
# For production builds:
#    - npm run build uses .env.production (if present)
#    - Alternatively, set env vars before build: VITE_API_BASE_URL=https://... npm run build
